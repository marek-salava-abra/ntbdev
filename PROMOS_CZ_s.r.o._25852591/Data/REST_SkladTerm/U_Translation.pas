const
  LOC = 'CZ';

function getString(id: String): String;
begin
  case LOC of
   'CZ': result := getStringCZ(id);
   'CH': result := getStringCH(id);
   'EN': result := getStringEN(id);
   'SK': result := getStringSK(id);
  end;
end;

